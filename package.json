{
  "name": "pear-social",
  "productName": "Pear Social",
  "description": "Decentralized P2P social network built on Hypercore Protocol",
  "author": "Pear Team",
  "private": true,
  "version": "0.2.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env WS_PORT=8888 DATA_PATH=./pear-social-data electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild",
    "postinstall": "electron-rebuild",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac && npm run sign:mac",
    "sign:mac": "codesign --deep --force --sign - 'release/mac-arm64/Pear Social.app' 2>/dev/null || true && codesign --deep --force --sign - 'release/mac/Pear Social.app' 2>/dev/null || true",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "lint": "eslint .",
    "test": "vitest run",
    "build:pwa": "cd pwa && npm install --legacy-peer-deps && npm run build",
    "dev:pwa": "cd pwa && npm run dev"
  },
  "build": {
    "appId": "com.pear.social",
    "productName": "Pear Social",
    "directories": {
      "output": "release"
    },
    "npmRebuild": true,
    "asar": true,
    "asarUnpack": [
      "node_modules/@roamhq/wrtc/**",
      "node_modules/sodium-native/**",
      "node_modules/sodium-universal/**",
      "node_modules/utp-native/**",
      "node_modules/node-gyp-build/**",
      "**/*.node"
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.{md,ts,map}",
      "!node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Pear Social needs microphone access for audio calls.",
        "NSCameraUsageDescription": "Pear Social needs camera access for video calls."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "win": {
      "executableName": "PearSocial",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "Pear Social",
      "perMachine": false,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "autobase": "^7.28.1",
    "b4a": "^1.8.1",
    "corestore": "^7.9.2",
    "hyperbee": "^2.27.3",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "localdrive": "^2.2.1",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "serve-handler": "^6.1.7",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "random-access-memory": "^6.2.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
